{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "link-memo-drive-api",
  "main": "src/index.js",
  "compatibility_date": "2026-07-13",
  "d1_databases": [
    {
      "binding": "DRIVE_CREDENTIALS",
      "database_name": "link-memo-drive-credentials",
      "database_id": "__D1_DATABASE_ID__"
    }
  ]
}
